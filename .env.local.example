# Salin file ini jadi .env.local lalu isi dengan nilai dari
# Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=isi-dengan-anon-public-key

# PENTING: jangan pernah taruh service_role key di sini atau di
# variabel NEXT_PUBLIC_* mana pun. Key itu bisa bypass semua RLS
# dan hanya boleh dipakai di server (misalnya Next.js Server Action
# atau Route Handler), tidak pernah dikirim ke browser.
